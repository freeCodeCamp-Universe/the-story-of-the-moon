{
  "name": "the-story-of-the-moon",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "pnpm lint:ts && prettier . --check",
    "lint:fix": "pnpm lint:ts:fix && prettier . --write",
    "lint:staged": "lint-staged",
    "lint:ts": "eslint .",
    "lint:ts:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "test:visual": "playwright test --project=chromium",
    "test:e2e": "playwright test --project=e2e",
    "test:visual:update": "playwright test --project=chromium --update-snapshots",
    "optimize:images": "node scripts/optimize-images.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,css,html,yaml,yml}": "prettier --write"
  },
  "dependencies": {
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "5.0.4",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^17.0.5",
    "prettier": "3.8.3",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.0",
    "vite": "7.1.7",
    "vitest": "4.0.7"
  }
}
